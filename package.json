{
  "name": "svg2tikz",
  "version": "0.1.0",
  "description": "Convert SVG files to TikZ (LaTeX) graphics",
  "type": "module",
  "main": "./dist/src/svg2tikz.js",
  "types": "./dist/src/svg2tikz.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/svg2tikz.d.ts",
      "browser": "./dist/browser/svg2tikz.js",
      "default": "./dist/src/svg2tikz.js"
    },
    "./node-env": {
      "types": "./dist/src/node-env.d.ts",
      "default": "./dist/src/node-env.js"
    }
  },
  "bin": {
    "svg2tikz": "dist/bin/svg2tikz.js"
  },
  "files": [
    "dist/src",
    "dist/bin",
    "dist/browser"
  ],
  "scripts": {
    "build": "tsc && esbuild src/svg2tikz.ts --bundle --format=esm --platform=browser --outfile=dist/browser/svg2tikz.js",
    "prepublishOnly": "npm run build && npm test",
    "predev": "npm run build",
    "dev": "npx serve -p 8123",
    "pretest": "npm run build",
    "test": "node --test dist/test/*.test.js",
    "gen-examples": "npm run build && node scripts/gen-readme-examples.js"
  },
  "keywords": [
    "svg",
    "tikz",
    "latex",
    "tex",
    "convert",
    "graphics",
    "vector"
  ],
  "author": "Dominik Peters",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DominikPeters/svg2tikz.js.git"
  },
  "bugs": {
    "url": "https://github.com/DominikPeters/svg2tikz.js/issues"
  },
  "homepage": "https://github.com/DominikPeters/svg2tikz.js#readme",
  "dependencies": {
    "jsdom": "^26.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
